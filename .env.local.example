# =============================================================================
# VOORBEELD — dit bestand wordt NIET door de app gelezen.
# Vul alles in in:  .env.local  (zelfde map)
# Zet hier NOOIT je echte API key — alleen in .env.local
# =============================================================================
# Account: https://app.liveavatar.com
# Fenna-tekst: src/lib/liveavatar/contexts/fenna-nl.json

# Python Fenna backend (voice gesprek) — lokaal poort 8000
NEXT_PUBLIC_HARTMAATJE_API_URL=http://localhost:8000

# --- Google Gemini (echte gesprekken + microfoon zonder inloggen) ---
# Maak een sleutel op: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Sneller voor stemgesprek (STT + antwoord) — standaard in code: gemini-2.5-flash-lite
# GEMINI_VOICE_MODEL=gemini-2.5-flash-lite
# Stem: alleen Gemini TTS (geen Windows-browserstem). Zet op false om fallback te testen.
# NEXT_PUBLIC_VOICE_GEMINI_ONLY=true

# --- Supabase (HartMaatje backend) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — for vector memory writes/reads (never expose in browser)
# SUPABASE_SERVICE_ROLE_KEY=
# MEMORY_USE_VECTOR=true
# MEMORY_EMBEDDING_DIM=768

# --- LiveAvatar / HeyGen — Fenna live avatar ---
# API key: Developers → API Key → Copy (alleen in .env.local plakken)
LIVEAVATAR_API_KEY=

# true = mag aan blijven; met eigen vrouwelijke avatar gebruikt de app automatisch
# een echte sessie (geen sandbox-test-man meer)
LIVEAVATAR_SANDBOX=true

# Context ID: Playground → Contexts → HartMaatje Fenna → ID kopiëren
LIVEAVATAR_FENNA_CONTEXT_ID=

# Avatar ID: Playground → Avatars → vrouwelijke avatar → ID uit de URL
# Voorbeeld URL: .../avatars/XXXXXXXX → dat is LIVEAVATAR_FENNA_AVATAR_ID
LIVEAVATAR_FENNA_AVATAR_ID=

# Optioneel — alleen nodig bij image-avatars zonder stem
# LIVEAVATAR_FENNA_VOICE_ID=

# Later — Maarten, Peter, Colette
# LIVEAVATAR_MAARTEN_AVATAR_ID=
# LIVEAVATAR_MAARTEN_CONTEXT_ID=
# LIVEAVATAR_PETER_AVATAR_ID=
# LIVEAVATAR_PETER_CONTEXT_ID=
# LIVEAVATAR_COLETTE_AVATAR_ID=
# LIVEAVATAR_COLETTE_CONTEXT_ID=
